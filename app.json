{
  "expo": {
    "name": "Sprout",
    "slug": "sprout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "sprout",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F5F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sprout.babytracker"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F5F0"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.sprout.babytracker"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7C9A8E"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Nodd needs camera access to analyze diaper contents."
        }
      ]
    ]
  }
}
